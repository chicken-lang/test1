# 统一换行符,避免跨平台 git diff 噪音
* text=auto eol=lf

# Windows 批处理保持 CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# 二进制文件不做换行转换
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.doc binary
*.docx binary
*.xls binary
*.xlsx binary
*.zip binary
*.gz binary
*.tar binary
*.min.js binary
*.min.css binary
