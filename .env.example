# ========== 数据库 ==========
# PostgreSQL 16 主库
# 端口 5432,默认库 jwc_dev,用户 jwc
POSTGRES_USER=jwc
POSTGRES_PASSWORD=jwc_dev_pwd_change_me
POSTGRES_DB=jwc_dev
# Prisma 连接串(被 apps/server 使用)
DATABASE_URL=postgresql://jwc:jwc_dev_pwd_change_me@localhost:5432/jwc_dev?schema=public

# ========== 缓存 ==========
# Redis 7
# 端口 6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ========== 搜索引擎 ==========
# Elasticsearch 8(含 IK 中文分词)
# 端口 9200,关闭安全认证便于本地开发
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URL=http://localhost:9200
# 索引名前缀
ES_INDEX_PREFIX=jwc_

# ========== 对象存储 ==========
# MinIO(兼容 S3)
# API 9000 / 控制台 9001
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=jwc_minio_admin
MINIO_SECRET_KEY=jwc_minio_pwd_change_me
MINIO_BUCKET=jwc-attachments
MINIO_REGION=cn-south-1

# ========== 消息队列 ==========
# RabbitMQ
# AMQP 5672 / 管理界面 15672
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=jwc
RABBITMQ_PASSWORD=jwc_mq_pwd_change_me
RABBITMQ_DEFAULT_VHOST=/

# ========== 应用 ==========
# 后端 API
SERVER_PORT=3000
API_PREFIX=/api/v1
# 前端 Nuxt runtimeConfig(Nuxt 读取 NUXT_ 前缀变量)
# 开发环境默认走 /api/v1 由 nitro proxy 转发到 WEB_API_PROXY
NUXT_PUBLIC_API_BASE=/api/v1
# JWT 密钥(生产环境务必替换)
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_EXPIRES=7d
# 前端代理目标
WEB_API_PROXY=http://localhost:3000
ADMIN_API_PROXY=http://localhost:3000
