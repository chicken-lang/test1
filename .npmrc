# pnpm 配置
# shamefully-hoist: 兼容部分未正确声明依赖的包(如 Element Plus 按需引入)
shamefully-hoist=true
# 严格 peer 依赖(开发期宽松,避免阻塞)
strict-peer-dependencies=false
# 自动安装 peers
auto-install-peers=true
# 镜像加速(国内)
registry=https://registry.npmmirror.com/
# 淘宝 binary 镜像(加速 node-gyp / esbuild / rollup 等二进制下载)
node-linker=isolated
